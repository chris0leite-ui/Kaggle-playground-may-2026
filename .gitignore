# Renamed during kickoff to .gitignore. The kickoff agent does this
# rename so this file does not get matched by the parent repo's
# .gitignore patterns.

# Data — keep placeholders, ignore content
data/*
!data/.gitkeep

# Submissions — only final submission CSVs tracked
submissions/*
!submissions/.gitkeep
!submissions/submission_*.csv

# Common data formats
*.csv
*.zip
*.parquet
*.feather
*.h5

# Override: final Kaggle submission CSVs are committed
!submissions/submission_*.csv

# Artifact policy (revised 2026-05-08, post-cleanup):
# Track .npy and .json under scripts/artifacts/, but block transient/junk.
scripts/artifacts/*.log
scripts/artifacts/*.db
scripts/artifacts/*.pkl
scripts/artifacts/*_fold[0-9]*.npy
scripts/artifacts/*_fold[0-9]*.json
scripts/artifacts/_smoke_*.npy
scripts/artifacts/_smoke_*.json
scripts/artifacts/tmp_*.npy
scripts/artifacts/scratch_*.npy
scripts/artifacts/*.txt
scripts/artifacts/*.csv
scripts/artifacts/*.csv.gz
scripts/artifacts/*.md

# Python
__pycache__/
*.py[cod]
*.egg-info/
.env
.venv/
venv/

# Kaggle credentials
.kaggle/

# Claude Code local settings (may contain secrets)
.claude/settings.local.json

# Jupyter
.ipynb_checkpoints/

# OS noise
.DS_Store
Thumbs.db

# Kaggle Dataset staging dir — only metadata + README tracked; hard-links
# to scripts/artifacts/* live here transiently for upload.
.kaggle-artifacts/*
!.kaggle-artifacts/dataset-metadata.json
!.kaggle-artifacts/README.md

# CatBoost training artifacts (auto-generated)
catboost_info/
kernels/d15b-dae-gpu/output/d15b_dae_X_*_latent.npy

# External Kaggle datasets pulled for reference (large CSVs; permissive licenses)
external/aadigupta_orig/
external/f1_official_1950_2022/
external/gkanamoto_tabm/
external/makimakiai_idsafe/
external/pavloivanin_baseline/
external/weather_woodshole/
# external/kernels/ (notebook sources) ARE checked in — small + load-bearing reference
kernels/d18-f1-replay-forensics-gpu/output/
scripts/artifacts/.*_announced
scripts/artifacts/d18_seq_done.flag
scripts/artifacts/d18_gate_hij_done.flag
scripts/artifacts/d18_hij_gates_done.flag
scripts/artifacts/d18_*_done.flag
